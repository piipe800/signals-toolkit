{
  "name": "@signals-toolkit/core",
  "version": "1.1.0",
  "description": "Utilities and helpers to simplify working with Angular Signals",
  "author": "Andrés Felipe León Sánchez",
  "license": "MIT",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --external @angular/core --external rxjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src/**/*.ts"
  },
  "peerDependencies": {
    "@angular/core": ">=16.0.0",
    "rxjs": ">=6.5.3"
  },
  "peerDependenciesMeta": {
    "rxjs": {
      "optional": true
    }
  },
  "devDependencies": {
    "@angular/core": "^18.0.0",
    "@eslint/js": "^9.39.4",
    "@vitest/coverage-v8": "^1.6.0",
    "eslint": "^9.39.4",
    "jsdom": "^24.0.0",
    "rxjs": "^7.8.0",
    "tslib": "^2.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0",
    "zone.js": "^0.14.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/piipe800/signals-toolkit"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "angular",
    "angular-signals",
    "signals",
    "computed-signal",
    "writable-signal",
    "signal-storage",
    "signal-utilities",
    "rxjs",
    "rxjs-interop",
    "debounce",
    "throttle",
    "localstorage",
    "state-management",
    "reactive",
    "typescript",
    "angular16",
    "angular17",
    "angular18"
  ]
}
